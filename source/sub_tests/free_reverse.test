TEST_CASE("free reverse returns reversed copy")
{
    List<int> l;

    l.push_back(1);
    l.push_back(2);
    l.push_back(3);

    auto r = reverse(l);

    auto it = r.begin();

    CHECK(*it == 3);
    ++it;

    CHECK(*it == 2);
    ++it;

    CHECK(*it == 1);
}

TEST_CASE("free reverse does not modify original")
{
    List<int> l;

    l.push_back(1);
    l.push_back(2);
    l.push_back(3);

    auto r = reverse(l);

    CHECK(l.front() == 1);
    CHECK(l.back() == 3);

    CHECK(r.front() == 3);
    CHECK(r.back() == 1);
}

